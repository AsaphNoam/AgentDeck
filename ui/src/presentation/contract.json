    "page-header": {
      "slots": ["eyebrow", "title", "description", "actions"],
      "states": [],
      "variants": ["default", "compact"]
    },
    "surface": {
      "slots": [],
      "states": [],
      "variants": ["default", "raised", "technical"]
    },
    "app-shell": {
      "slots": ["mark", "wordmark", "navigation", "connection", "main"],
      "states": [],
      "variants": []
    },
