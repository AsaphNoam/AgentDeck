    "--ad-surface-raised",
    "--ad-surface-subtle",
    "--ad-surface-emphasis",
    "--ad-text-primary",
    "--ad-text-secondary",
    "--ad-text-muted",
    "--ad-text-inverse",
    "--ad-border-default",
    "--ad-border-strong",
